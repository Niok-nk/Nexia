---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Dashboard" subtitle="Resumen general del CRM">
  <!-- Stats Grid -->
  <div class="stat-grid" id="stats-grid">
    <div class="stat-card" style="--accent: var(--color-wa)">
      <div class="stat-label">Contactos</div>
      <div class="stat-value" id="stat-contacts">—</div>
    </div>
    <div class="stat-card" style="--accent: var(--color-blue)">
      <div class="stat-label">Leads activos</div>
      <div class="stat-value" id="stat-leads">—</div>
    </div>
    <div class="stat-card" style="--accent: var(--color-purple)">
      <div class="stat-label">Mensajes hoy</div>
      <div class="stat-value" id="stat-messages">—</div>
    </div>
    <div class="stat-card" style="--accent: var(--color-wa)">
      <div class="stat-label">Ventas cerradas</div>
      <div class="stat-value" id="stat-won">—</div>
    </div>
  </div>

  <div class="grid-2">
    <!-- Últimos contactos -->
    <div class="card">
      <div class="card-title">Últimos contactos</div>
      <div id="recent-contacts">
        <div class="text-muted text-sm animate-pulse">Cargando...</div>
      </div>
    </div>

    <!-- Leads por módulo -->
    <div class="card">
      <div class="card-title">Leads por módulo</div>
      <div id="leads-by-module">
        <div class="text-muted text-sm animate-pulse">Cargando...</div>
      </div>
    </div>
  </div>

  <!-- Leads recientes -->
  <div class="card mt-4">
    <div class="card-title">Leads recientes</div>
    <div class="table-wrap" id="recent-leads-wrap">
      <div class="text-muted text-sm animate-pulse" style="padding:1rem;">Cargando...</div>
    </div>
  </div>
</Layout>

<script>
  const API = window.API || 'http://localhost:8000/api/v1';

  function fmtPhone(p: string) {
    return p ? p.replace(/(\d{2})(\d{3})(\d{3})(\d{4})/, '+$1 $2 $3 $4') : '—';
  }

  function stageLabel(s: string) {
    const m: Record<string, string> = {
      INITIAL: 'Nuevo',
      CIUDAD_VALIDADA: 'Ciudad Validada',
      PRODUCTO_INTERES: 'Interés Producto',
      CONTACTO_COMPLETO: 'Contacto Completo',
      PRESUPUESTO_LISTO: 'Presupuesto Listo',
      VENTA_CERRADA: 'Venta Cerrada',
      RECHAZADO: 'Rechazado',
    };
    return m[s] || s;
  }

  async function loadDashboard() {
    try {
      const [contactsRes, leadsRes] = await Promise.all([
        apiFetch(`${API}/contacts?_t=${Date.now()}`),
        apiFetch(`${API}/leads?_t=${Date.now()}`),
      ]);
      const contacts = await contactsRes.json();
      const leads = await leadsRes.json();

      // Stats
      document.getElementById('stat-contacts')!.textContent = String(contacts.length);
      document.getElementById('stat-leads')!.textContent = String(leads.filter((l: any) => l.stage !== 'VENTA_CERRADA' && l.stage !== 'RECHAZADO').length);
      document.getElementById('stat-won')!.textContent = String(leads.filter((l: any) => l.stage === 'VENTA_CERRADA').length);

      // Messages count (via leads messages)
      const today = new Date().toDateString();
      let msgCount = 0;
      leads.forEach((l: any) => {
        l.contact?.messages?.forEach((m: any) => {
          if (new Date(m.sentAt).toDateString() === today) msgCount++;
        });
      });
      document.getElementById('stat-messages')!.textContent = msgCount ? String(msgCount) : '—';

      // Recent contacts
      const recentContacts = contacts.slice(-5).reverse();
      document.getElementById('recent-contacts')!.innerHTML = recentContacts.length
        ? recentContacts.map((c: any) => `
          <a href="/contacts/${c.id}" style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 0;border-bottom:1px solid var(--color-border-light);text-decoration:none;color:inherit;">
            <div style="width:36px;height:36px;border-radius:50%;background:var(--color-wa-glow);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;color:var(--color-wa);">C</div>
            <div>
              <div style="font-weight:600;font-size:0.85rem;">${c.name || 'Sin nombre'}</div>
              <div class="text-muted font-mono text-xs">${fmtPhone(c.realPhone || c.phone)}</div>
            </div>
          </a>`).join('')
        : '<div class="text-muted text-sm">Sin contactos aún.</div>';

      // Leads by module
      const moduleCount: Record<string, number> = {};
      leads.forEach((l: any) => { moduleCount[l.module] = (moduleCount[l.module] || 0) + 1; });
      const moduleColors: Record<string, string> = {
        VENTAS: 'var(--mod-ventas)', CARTERA: 'var(--mod-cartera)',
        SERVICIO_TECNICO: 'var(--mod-tecnico)', REPUESTOS: 'var(--mod-repuestos)',
        VACANTES: 'var(--mod-vacantes)', DISTRIBUIDORES: 'var(--mod-distribuidores)',
        MEDIOS_DE_PAGO: 'var(--mod-pagos)',
        CREDITO: 'var(--mod-credito)',
      };
      const total = leads.length || 1;
      document.getElementById('leads-by-module')!.innerHTML = Object.entries(moduleCount)
        .sort((a, b) => b[1] - a[1])
        .map(([mod, count]) => `
          <div style="margin-bottom:0.75rem;">
            <div style="display:flex;justify-content:space-between;font-size:0.8rem;margin-bottom:0.3rem;">
              <span class="badge badge-${mod}">${mod.replace(/_/g,' ')}</span>
              <span class="text-muted">${count}</span>
            </div>
            <div style="height:4px;background:var(--color-bg-hover);border-radius:99px;overflow:hidden;">
              <div style="height:100%;width:${Math.round(count/total*100)}%;background:${moduleColors[mod]||'var(--color-wa)'};border-radius:99px;transition:width 0.6s;"></div>
            </div>
          </div>`).join('') || '<div class="text-muted text-sm">Sin leads.</div>';

      // Recent leads table
      const recentLeads = leads.slice(-10).reverse();
      document.getElementById('recent-leads-wrap')!.innerHTML = `
        <table>
          <thead><tr>
            <th>Contacto</th><th>Teléfono</th><th>Módulo</th><th>Etapa</th><th>Fecha</th><th></th>
          </tr></thead>
          <tbody>
            ${recentLeads.map((l: any) => `
              <tr>
                <td>${l.contact?.name || 'Sin nombre'}</td>
                <td class="font-mono text-xs">${fmtPhone(l.contact?.realPhone || l.contact?.phone)}</td>
                <td><span class="badge badge-${l.module}">${l.module?.replace(/_/g,' ')}</span></td>
                <td><span class="badge badge-${l.stage}">${stageLabel(l.stage)}</span></td>
                <td class="text-muted text-xs">${new Date(l.createdAt).toLocaleDateString('es-CO')}</td>
                <td><a href="/contacts/${l.contactId}" class="btn btn-ghost" style="padding:0.2rem 0.6rem;font-size:0.75rem;">Ver</a></td>
              </tr>`).join('') || '<tr><td colspan="6" class="text-muted" style="text-align:center;padding:2rem;">Sin leads aún.</td></tr>'}
          </tbody>
        </table>`;
    } catch (err) {
      console.error('Dashboard load error:', err);
    }
  }

  loadDashboard();
  setInterval(loadDashboard, 15000);
</script>
