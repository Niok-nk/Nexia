---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
const { id } = Astro.params;
---
<Layout title="Detalle de Contacto" subtitle="Historial completo de conversación">
  <fragment slot="header-actions">
    <a href="/contacts" class="btn btn-ghost">← Volver</a>
  </fragment>

  <div id="contact-detail">
    <div class="animate-pulse text-muted">Cargando...</div>
  </div>
</Layout>

<script define:vars={{ contactId: id }}>
  const API = window.API || 'http://localhost:8000/api/v1';

  let currentContact = null;
  let currentSessionIdx = 0;

  function fmtTime(d) {
    return new Date(d).toLocaleString('es-CO', { hour:'2-digit', minute:'2-digit', day:'2-digit', month:'short' });
  }
  function fmtDate(d) {
    return new Date(d).toLocaleDateString('es-CO', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
  }
  function stageLabel(s) {
    const m = {
      INITIAL: 'Nuevo',
      CIUDAD_VALIDADA: 'Ciudad Validada',
      PRODUCTO_INTERES: 'Interés Producto',
      CONTACTO_COMPLETO: 'Contacto Completo',
      PRESUPUESTO_LISTO: 'Presupuesto Listo',
      VENTA_CERRADA: 'Venta Cerrada',
      RECHAZADO: 'Rechazado',
    };
    return m[s] || s;
  }

  const STAGE_OPTIONS = [
    'INITIAL',
    'CIUDAD_VALIDADA',
    'PRODUCTO_INTERES',
    'CONTACTO_COMPLETO',
    'PRESUPUESTO_LISTO',
    'VENTA_CERRADA',
    'RECHAZADO',
  ];

  function renderUserDataCard(u) {
    if (!u) return '';
    const fields = [
      ['Nombre', u.nombre],
      ['Cédula', u.cedula],
      ['Teléfono', u.telefono],
      ['Ciudad', u.ciudad],
      ['Departamento', u.departamento],
      ['Dirección', u.direccion],
      ['Producto solicitado', u.productoSolicitado],
      ['Presupuesto', u.presupuesto],
    ].filter(([, v]) => v);
    let extraHtml = '';
    try {
      const extra = JSON.parse(u.extra || '{}');
      const extraFields = Object.entries(extra).filter(([k, v]) => v && !['__v', '_id', 'perfilState', 'perfil_state', 'perfilCompleto', 'flujo', 'productosPreCargados', 'productos_pre_cargados', 'ultimaBusqueda', 'ultima_busqueda', 'productoSolicitado', 'producto_solicitado', 'nombre', 'cedula', 'telefono', 'ciudad', 'departamento', 'direccion', 'presupuesto'].includes(k));
      if (extraFields.length) {
        extraHtml = extraFields.map(([k, v]) => {
          const val = typeof v === 'object' ? JSON.stringify(v) : String(v);
          return `<div style="background:var(--color-bg-hover);border-radius:var(--radius-md);padding:0.5rem 0.65rem;min-width:0;">
            <div class="text-xs text-muted" style="margin-bottom:0.15rem;">${k.replace(/([A-Z])/g,' $1').replace(/^./,s=>s.toUpperCase())}</div>
            <div style="font-size:0.85rem;overflow-wrap:anywhere;line-height:1.3;">${val}</div>
          </div>`;
        }
        ).join('');
      }
    } catch {}
    if (!fields.length && !extraHtml) return '';
    return `
    <div class="card mb-4">
      <div class="card-title">Datos del cliente</div>
      ${fields.length ? `
      <div style="display:grid;grid-template-columns:1fr;gap:0.5rem;min-width:0;">
        ${fields.map(([label, val]) => `
        <div style="background:var(--color-bg-hover);border-radius:var(--radius-md);padding:0.5rem 0.65rem;min-width:0;">
          <div class="text-xs text-muted" style="margin-bottom:0.15rem;">${label}</div>
          <div style="font-size:0.85rem;overflow-wrap:anywhere;line-height:1.3;">${val}</div>
        </div>`).join('')}
      </div>` : ''}
      ${extraHtml ? `
      <div style="margin-top:${fields.length ? '0.75rem' : '0'};display:grid;grid-template-columns:1fr;gap:0.5rem;min-width:0;">
        ${extraHtml}
      </div>` : ''}
    </div>`;
  }

  function renderLeadCard(lead) {
    if (!lead) return '<div class="card mb-4 text-muted text-sm">Sin lead activo. El contacto aún no ha interactuado.</div>';
    return `
    <div class="card mb-4">
      <div class="card-title">Lead activo</div>
      <div style="margin-bottom:0.75rem;">
        <div class="text-xs text-muted mb-4">Módulo</div>
        <span class="badge badge-${lead.module}">${lead.module?.replace(/_/g,' ')}</span>
      </div>
      <div style="margin-bottom:0.75rem;">
        <div class="text-xs text-muted mb-4">Etapa</div>
        <select id="stage-select" class="form-input w-full" style="font-size:0.8rem;padding:0.4rem;">
          ${STAGE_OPTIONS.map(s => `<option value="${s}" ${s === lead.stage ? 'selected' : ''}>${stageLabel(s)}</option>`).join('')}
        </select>
      </div>
      <button onclick="addNote('${lead.id}')" class="btn btn-ghost w-full" style="font-size:0.8rem;justify-content:center;">
        Agregar nota
      </button>
      ${lead.notes?.length ? `
      <div style="margin-top:1rem;">
        <div class="text-xs text-muted mb-4">Notas (${lead.notes.length})</div>
        ${lead.notes.map((n) => `
          <div style="background:var(--color-bg-hover);border-radius:var(--radius-md);padding:0.5rem 0.75rem;margin-top:0.4rem;font-size:0.8rem;">
            <div>${n.body}</div>
            <div class="text-muted text-xs">${fmtTime(n.createdAt)}</div>
          </div>`).join('')}
      </div>` : ''}
    </div>`;
  }

  function setSession(i) {
    currentSessionIdx = i;
    renderContact();
  }

  function renderContact() {
    const c = currentContact;
    if (!c) return;
    const container = document.getElementById('contact-detail');
    const sortedLeads = (c.leads || []).sort((a, b) => new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime());
    const messages = c.messages?.sort((a, b) => new Date(a.sentAt).getTime() - new Date(b.sentAt).getTime()) || [];
    const lead = sortedLeads[currentSessionIdx] || sortedLeads[sortedLeads.length - 1];

    const sessionTabs = sortedLeads.map((l, i) =>
      `<button onclick="setSession(${i})" style="flex:1;padding:0.5rem;font-size:0.75rem;border:1px solid var(--color-border);border-radius:var(--radius-md);cursor:pointer;background:${i === currentSessionIdx ? 'var(--color-primary)' : 'var(--color-bg-hover)'};color:${i === currentSessionIdx ? '#fff' : 'var(--color-text)'};" title="${fmtDate(l.createdAt)}">
        ${i + 1}
      </button>`
    ).join('');

    container.innerHTML = `
      <div style="display:grid;grid-template-columns:340px 1fr;gap:1.5rem;align-items:start;">
        <!-- Info Panel -->
        <div>
          <div class="card mb-4">
            <div style="text-align:center;padding-bottom:1rem;border-bottom:1px solid var(--color-border);margin-bottom:1rem;">
              <div style="width:64px;height:64px;border-radius:50%;background:var(--color-wa-glow);display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 0.75rem;color:var(--color-wa);">C</div>
              <div style="font-size:1.1rem;font-weight:700;">${c.name || 'Sin nombre'}</div>
              <div class="font-mono text-muted text-xs">${c.realPhone || c.phone}</div>
              ${c.email ? `<div class="text-muted text-xs">${c.email}</div>` : ''}
            </div>
            <div class="text-xs text-muted">Desde ${new Date(c.createdAt).toLocaleDateString('es-CO')}</div>
          </div>

          ${sortedLeads.length > 1 ? `
          <div class="card mb-4">
            <div class="card-title">Sesiones</div>
            <div style="display:flex;gap:0.4rem;">${sessionTabs}</div>
            <div class="text-xs text-muted" style="margin-top:0.4rem;">${fmtDate(lead.createdAt)}</div>
          </div>` : ''}

          ${renderLeadCard(lead)}
          ${renderUserDataCard(lead?.userData)}
        </div>

        <!-- Chat History -->
        <div class="card" style="padding:0;overflow:hidden;">
          <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--color-border);font-size:0.75rem;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.06em;">
            Historial de mensajes (${messages.length})
          </div>
          <div class="msg-list" style="max-height:600px;overflow-y:auto;">
            ${messages.length ? messages.map((m) => `
              <div class="msg-item ${m.direction === 'INBOUND' ? 'msg-inbound' : 'msg-outbound'}">
                <div class="msg-bubble ${m.direction === 'INBOUND' ? 'inbound' : 'outbound'}">
                  ${m.body}
                  <div class="msg-meta">
                    ${m.agentType ? `${m.agentType} · ` : ''}${fmtTime(m.sentAt)}
                  </div>
                </div>
              </div>`).join('')
            : '<div class="text-muted text-sm" style="text-align:center;padding:2rem;">Sin mensajes aún.</div>'}
          </div>
          <!-- Send Message -->
          <div style="padding:1rem;border-top:1px solid var(--color-border);display:flex;gap:0.5rem;">
            <input type="text" id="manual-msg-input" class="form-input" style="flex:1;font-size:0.875rem;" placeholder="Escribe un mensaje..." />
            <button onclick="sendManualMsg()" class="btn btn-primary" style="padding:0.5rem 1rem;font-size:0.875rem;">Enviar</button>
          </div>
        </div>
      </div>`;

    // Stage change handler
    const stageSelect = document.getElementById('stage-select');
    if (stageSelect && lead) {
      stageSelect.addEventListener('change', (e) => {
        changeStage(lead.id, e.target.value);
      });
    }

    // Scroll chat to bottom
    const msgList = document.querySelector('.msg-list');
    if (msgList) msgList.scrollTop = msgList.scrollHeight;

    // Manual message handler
    const msgInput = document.getElementById('manual-msg-input');
    msgInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') sendManualMsg();
    });
  }

  async function changeStage(leadId, stage) {
    await apiFetch(`${API}/leads/${leadId}/stage`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ stage }),
    });
    loadContact();
  }

  async function addNote(leadId) {
    const body = prompt('Escribe la nota interna:');
    if (!body?.trim()) return;
    await apiFetch(`${API}/leads/${leadId}/notes`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ body }),
    });
    loadContact();
  }

  async function loadContact() {
    const container = document.getElementById('contact-detail');
    try {
      const res = await apiFetch(`${API}/contacts/${contactId}`);
      if (!res.ok) { container.innerHTML = '<div class="text-muted">Contacto no encontrado.</div>'; return; }
      currentContact = await res.json();
      currentSessionIdx = currentContact.leads ? currentContact.leads.length - 1 : 0;
      renderContact();
      window.addNote = addNote;
      window.sendManualMsg = sendManualMsg;
      window.setSession = setSession;
    } catch (err) {
      container.innerHTML = `<div class="text-muted">Error cargando el contacto.</div>`;
    }
  }

  async function sendManualMsg() {
    const input = document.getElementById('manual-msg-input');
    const msg = input?.value?.trim();
    if (!msg) return;

    try {
      const res = await apiFetch(`${API}/whatsapp/send`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to: currentContact?.phone, message: msg }),
      });
      const data = await res.json();
      if (res.ok) {
        input.value = '';
        loadContact();
      } else if (res.status === 503) {
        alert('⚠️ WhatsApp no está conectado.\n\nVe a la página de WhatsApp en el panel y escanea el QR para conectar.');
      } else {
        alert(data.error || 'Error al enviar mensaje');
      }
    } catch {
      alert('❌ Error de conexión.\n\nEl servidor no responde. Verifica que el backend esté corriendo.');
    }
  }

  loadContact();
</script>
