---
import Layout from '../layouts/Layout.astro';
---
<Layout title="WhatsApp" subtitle="Estado de sesión y mensajes recientes">
  <div class="grid-2" style="align-items:start;">
    <!-- QR / Status Panel -->
    <div class="card">
      <div class="card-title">Estado de sesión</div>

      <div id="status-panel">
        <div class="animate-pulse text-muted">Verificando estado...</div>
      </div>

      <div style="margin-top:1.5rem;display:flex;gap:0.75rem;">
        <button onclick="refreshStatus()" class="btn btn-ghost" style="font-size:0.8rem;">
          Actualizar
        </button>
        <button
          id="send-btn"
          onclick="toggleSendForm()"
          class="btn btn-primary"
          style="font-size:0.8rem;"
          disabled
        >
          Enviar mensaje
        </button>
      </div>

      <!-- Send Form (hidden by default) -->
      <div id="send-form" style="display:none;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--color-border);">
        <div class="form-group">
          <label class="form-label" for="send-to">Número destino (con código de país)</label>
          <input class="form-input w-full" type="text" id="send-to" placeholder="573001234567" />
        </div>
        <div class="form-group">
          <label class="form-label" for="send-msg">Mensaje</label>
          <textarea class="form-input w-full" id="send-msg" rows="3" placeholder="Escribe el mensaje..."></textarea>
        </div>
        <button onclick="sendMsg()" class="btn btn-primary" style="font-size:0.85rem;">Enviar</button>
        <div id="send-result" style="margin-top:0.75rem;font-size:0.8rem;"></div>
      </div>
    </div>

    <!-- Recent messages -->
    <div class="card">
      <div class="card-title">Últimos mensajes recibidos</div>
      <div id="recent-msgs">
        <div class="animate-pulse text-muted">Cargando...</div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const API = window.API || 'http://localhost:8000/api/v1';

  async function refreshStatus() {
    const panel = document.getElementById('status-panel')!;
    try {
      const res = await apiFetch(`${API}/whatsapp/status`);
      const { status } = await res.json();
      const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
      sendBtn.disabled = status !== 'connected';

      if (status === 'connected') {
        panel.innerHTML = `
          <div style="display:flex;align-items:center;gap:0.75rem;background:var(--color-wa-glow);border:1px solid var(--color-wa);border-radius:var(--radius-md);padding:1rem;">
            <div class="wa-dot connected"></div>
            <div>
              <div style="font-weight:600;color:var(--color-wa);">WhatsApp Conectado</div>
              <div class="text-muted text-xs">El bot está activo y recibiendo mensajes</div>
            </div>
          </div>`;
      } else if (status === 'qr_pending') {
        // Load QR image
        const qrRes = await apiFetch(`${API}/whatsapp/qr`);
        const { qr } = await qrRes.json();
        panel.innerHTML = `
          <div style="text-align:center;">
            <div class="wa-dot qr_pending" style="margin:0 auto 1rem;width:12px;height:12px;"></div>
            <p style="margin-bottom:1rem;font-size:0.85rem;color:var(--color-text-muted);">Escanea el código QR con WhatsApp</p>
            <img src="${qr}" alt="QR Code" class="qr-img" style="margin:0 auto;" />
            <p class="text-muted text-xs" style="margin-top:0.75rem;">WhatsApp → Dispositivos vinculados → Vincular dispositivo</p>
          </div>`;
      } else {
        panel.innerHTML = `
          <div style="text-align:center;padding:1.5rem;">
            <div style="font-size:2rem;margin-bottom:0.5rem;"></div>
            <div style="font-weight:600;color:var(--color-red);">Desconectado</div>
            <div class="text-muted text-xs" style="margin-bottom:1rem;">El cliente de WhatsApp no está conectado</div>
            <button onclick="reconnectWA()" class="btn btn-primary" style="font-size:0.85rem;">Reconectar</button>
            <div id="reconnect-status" style="margin-top:0.75rem;font-size:0.8rem;"></div>
          </div>`;
      }
    } catch {
      panel.innerHTML = '<div class="text-muted text-sm">Error verificando estado del servidor.</div>';
    }
  }

  async function loadRecentMessages() {
    const el = document.getElementById('recent-msgs')!;
    try {
      const res = await apiFetch(`${API}/contacts?_t=${Date.now()}`);
      const contacts = await res.json();
      const allMsgs: any[] = [];
      contacts.forEach((c: any) => {
        (c.messages || []).forEach((m: any) => {
          allMsgs.push({ ...m, contactName: c.name || c.phone, contactId: c.id });
        });
      });
      allMsgs.sort((a, b) => new Date(b.sentAt).getTime() - new Date(a.sentAt).getTime());
      const recent = allMsgs.slice(0, 15);
      if (!recent.length) { el.innerHTML = '<div class="text-muted text-sm">Sin mensajes.</div>'; return; }
      el.innerHTML = recent.map(m => `
        <a href="/contacts/${m.contactId}" style="display:flex;gap:0.75rem;padding:0.6rem 0;border-bottom:1px solid var(--color-border-light);text-decoration:none;color:inherit;">
          <div style="flex-shrink:0;font-size:0.8rem;color:var(--color-text-muted);">${m.direction === 'INBOUND' ? 'In' : 'Out'}</div>
          <div style="flex:1;min-width:0;">
            <div style="display:flex;justify-content:space-between;margin-bottom:0.2rem;">
              <span style="font-weight:600;font-size:0.8rem;">${m.contactName}</span>
              <span class="text-muted text-xs">${new Date(m.sentAt).toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'})}</span>
            </div>
            <div class="text-muted text-xs" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              ${m.body?.slice(0,80)}${m.body?.length > 80 ? '...' : ''}
            </div>
            ${m.agentType ? `<span class="badge" style="font-size:0.6rem;margin-top:0.25rem;background:var(--color-bg-hover);color:var(--color-text-muted);">${m.agentType}</span>` : ''}
          </div>
        </a>`).join('');
    } catch {
      el.innerHTML = '<div class="text-muted text-sm">Error cargando mensajes.</div>';
    }
  }

  function toggleSendForm() {
    const form = document.getElementById('send-form')!;
    form.style.display = form.style.display === 'none' ? 'block' : 'none';
  }

  async function sendMsg() {
    const to = (document.getElementById('send-to') as HTMLInputElement).value.trim();
    const message = (document.getElementById('send-msg') as HTMLTextAreaElement).value.trim();
    const result = document.getElementById('send-result')!;
    if (!to || !message) { result.innerHTML = '<span style="color:var(--color-red);">Completa todos los campos.</span>'; return; }
    try {
      const res = await apiFetch(`${API}/whatsapp/send`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to, message }),
      });
      const data = await res.json();
      if (res.ok) {
        result.innerHTML = '<span style="color:var(--color-wa);">Mensaje enviado correctamente.</span>';
        (document.getElementById('send-msg') as HTMLTextAreaElement).value = '';
      } else {
        result.innerHTML = `<span style="color:var(--color-red);">${data.error}</span>`;
      }
    } catch {
      result.innerHTML = '<span style="color:var(--color-red);">Error de conexión.</span>';
    }
  }

  async function reconnectWA() {
    const statusEl = document.getElementById('reconnect-status')!;
    statusEl.innerHTML = '<span style="color:var(--color-wa);">Reconectando...</span>';
    try {
      const res = await apiFetch(`${API}/whatsapp/reconnect`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();
      if (res.ok) {
        statusEl.innerHTML = '<span style="color:var(--color-wa);">Reconectando. Espera el QR...</span>';
        setTimeout(refreshStatus, 3000);
      } else {
        statusEl.innerHTML = `<span style="color:var(--color-red);">${data.error || 'Error al reconectar'}</span>`;
      }
    } catch {
      statusEl.innerHTML = '<span style="color:var(--color-red);">Error de conexión.</span>';
    }
  }

  (window as any).refreshStatus = refreshStatus;
  (window as any).toggleSendForm = toggleSendForm;
  (window as any).sendMsg = sendMsg;
  (window as any).reconnectWA = reconnectWA;

  refreshStatus();
  loadRecentMessages();
  setInterval(loadRecentMessages, 15000);
</script>
