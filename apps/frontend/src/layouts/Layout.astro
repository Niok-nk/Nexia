---
import '../styles/global.css';
import AIChat from '../components/AIChat.astro';

interface Props {
  title?: string;
  subtitle?: string;
  showSidebar?: boolean;
}
const { title = 'CRM Dashboard', subtitle, showSidebar = true } = Astro.props;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/dashboard',  label: 'Dashboard'   },
  { href: '/pipeline',   label: 'Pipeline'    },
  { href: '/contacts',   label: 'Contactos'   },
  { href: '/whatsapp',   label: 'WhatsApp'    },
];
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="CRM Dashboard — Chatbot IA + WhatsApp" />
  <title>{title} · CRM IA</title>
</head>
<body>
{showSidebar ? (
  <div class="app-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <div class="logo-icon">Nex</div>
        <div>
          <div class="logo-text">Nexia</div>
          <div class="logo-sub">WhatsApp Bot IA</div>
        </div>
      </div>
      <nav class="sidebar-nav">
        <div class="nav-section">
          <div class="nav-section-label">Principal</div>
          {navItems.map(item => (
            <a
              href={item.href}
              class={`nav-link ${currentPath === item.href ? 'active' : ''}`}
            >
              {item.label}
            </a>
          ))}
        </div>
      </nav>

      <div class="sidebar-footer">
        <div class="wa-status-badge" id="wa-status-badge">
          <div class="wa-dot" id="wa-dot"></div>
          <span id="wa-status-text">Verificando...</span>
        </div>
        <div style="margin-top:0.75rem;">
          <button
            onclick="logout()"
            class="btn btn-ghost w-full"
            style="font-size:0.75rem; justify-content:center; padding:0.4rem;"
          >
            Cerrar sesión
          </button>
        </div>
      </div>
    </aside>

    <!-- Main -->
    <div class="main-content">
      {(title || subtitle) && (
        <header class="page-header">
          <div>
            <div class="page-title">{title}</div>
            {subtitle && <div class="page-subtitle">{subtitle}</div>}
          </div>
          <slot name="header-actions" />
        </header>
      )}
      <main class="page-body animate-fade-in">
        <slot />
      </main>
    </div>
  </div>
) : (
  <slot />
)}

<script define:vars={{ API }}>
  /**
   * Decodifica payload de un JWT sin verificar firma (solo para leer exp).
   */
  function jwtPayload(token) {
    try {
      return JSON.parse(atob(token.split('.')[1]));
    } catch {
      return null;
    }
  }

  /**
   * Auth guard: chequea que el token exista Y no haya expirado.
   */
  const token = localStorage.getItem('crm_token');
  if (!window.location.pathname.includes('/login')) {
    if (!token) {
      window.location.href = '/login';
    } else {
      const payload = jwtPayload(token);
      if (!payload || Date.now() >= payload.exp * 1000) {
        localStorage.removeItem('crm_token');
        window.location.href = '/login';
      }
    }
  }

  /**
   * fetchWrapper — cualquier 401 cierra sesión automáticamente.
   */
  async function apiFetch(url, options = {}) {
    const tok = localStorage.getItem('crm_token');
    const res = await fetch(url, {
      ...options,
      headers: {
        'Authorization': tok ? `Bearer ${tok}` : '',
        ...options.headers,
      },
    });
    if (res.status === 401 && !window.location.pathname.includes('/login')) {
      localStorage.removeItem('crm_token');
      window.location.href = '/login';
      throw new Error('Sesión expirada');
    }
    return res;
  }
  window.apiFetch = apiFetch;
  window.API = API;

  // WA status polling
  async function updateWAStatus() {
    const dot = document.getElementById('wa-dot');
    const txt = document.getElementById('wa-status-text');
    if (!dot || !txt) return;
    try {
      const res = await apiFetch(`${API}/whatsapp/status`);
      if (!res.ok) return;
      const { status } = await res.json();
      dot.className = `wa-dot ${status}`;
      const labels = { connected: 'Conectado', qr_pending: 'Escaneando QR', disconnected: 'Desconectado' };
      txt.textContent = labels[status] || status;
    } catch {}
  }

  updateWAStatus();
  setInterval(updateWAStatus, 10000);

  function logout() {
    localStorage.removeItem('crm_token');
    window.location.href = '/login';
  }
  window.logout = logout;
</script>

<AIChat />
</body>
</html>